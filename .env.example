# 复制本文件为 .env 并填写；.env 已在 .gitignore 中，切勿提交。

# ── MariaDB ─────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=changeme

# ── Nextcloud 首次自动安装（成功后可在 docker-compose 中删除或置空）────
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=changeme

# ── 对外 URL（须与浏览器访问地址一致）──────────────────────────
# 若 HTTPS 在 GCP LB / CDN 终止：LB 需传入 X-Forwarded-Proto / X-Forwarded-Port，
# Nginx 已透传；此处 OVERWRITE* / PUBLIC_URL 用 https 与域名保持一致。
# 若用户直连本机仅 HTTP:80，则下列协议须为 http。
NEXTCLOUD_PUBLIC_URL=http://test.neweggbox.com
NEXTCLOUD_TRUSTED_DOMAINS=test.neweggbox.com
NEXTCLOUD_OVERWRITE_PROTOCOL=http
NEXTCLOUD_OVERWRITE_HOST=test.neweggbox.com

# ── Redis（与 Nextcloud、PHP 会话共用）。不设口令：不要出现下行（勿写空值）。
# REDIS_HOST_PASSWORD=请改为强随机口令
# 可选：内存上限（默认 256mb，整机内存大时可 512mb、1gb）
# REDIS_MAXMEMORY=512mb

# ── 可选：收紧 trusted_proxies（空格分隔 IP / CIDR）；不设则用 compose 默认值
# TRUSTED_PROXIES=127.0.0.1 172.18.0.0/16
